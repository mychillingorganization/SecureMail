{
  "schema_version": "1.0",
  "description": "Template for SecureMail scan request/response with resilient agent states",
  "notes": [
    "Use request_templates for calling orchestrator endpoints.",
    "Use response_templates to normalize UI and downstream processing.",
    "When an agent is unavailable, keep the agent object with status=missing."
  ],
  "section_explanations": {
    "schema_version": "Version of this template format. Increase only when structure changes.",
    "description": "Human-readable purpose of this template file.",
    "notes": "Quick operating notes for developers and QA.",
    "request_templates": "Canonical request payloads per orchestrator endpoint.",
    "response_templates": "Normalized response payloads for each runtime scenario.",
    "normalization_rules": "Mandatory rules to keep downstream consumers stable.",
    "why_meta_exists": "meta carries traceability fields (request_id/timestamp/version) for audit and debugging.",
    "why_runtime_exists": "runtime states degraded_mode and missing_agents so UI/services can show partial availability clearly.",
    "why_orchestrator_exists": "orchestrator is the final source-of-truth for verdict and execution logs.",
    "why_agents_exists": "agents keeps per-agent detail even when unavailable/skipped to avoid schema breaks.",
    "why_keep_missing_agent_object": "A fixed object shape prevents null checks and fragile client parsing when an agent is down."
  },
  "field_guide": {
    "meta": {
      "request_id": "Unique ID to correlate logs across services.",
      "timestamp": "ISO-8601 UTC time of generated result.",
      "version": "Response schema version for compatibility checks."
    },
    "runtime": {
      "degraded_mode": "true when one or more agents are unavailable.",
      "missing_agents": "List of unavailable agent names.",
      "available_agents": "Boolean map of current agent availability."
    },
    "orchestrator": {
      "final_status": "PASS | WARNING | DANGER from orchestration policy.",
      "issue_count": "Total warning counters accumulated during pipeline.",
      "termination_reason": "Populated when early termination/kill-switch happened.",
      "execution_logs": "Ordered step logs for debugging and explainability."
    },
    "agent_object": {
      "enabled": "Whether this agent was expected to run in this scenario.",
      "status": "ok | missing | skipped | error.",
      "risk_score": "Normalized risk number used for downstream interpretation.",
      "label": "safe | suspicious | malicious | unknown.",
      "issues": "List of detected indicators from that agent.",
      "error": "Human-readable error when unavailable/failure.",
      "raw": "Original pass-through payload from the agent for deep debugging."
    }
  },
  "request_templates": {
    "scan_basic": {
      "endpoint": "/api/v1/scan",
      "method": "POST",
      "body": {
        "email_path": "./test4.eml",
        "user_accepts_danger": false
      }
    },
    "scan_llm": {
      "endpoint": "/api/v1/scan-llm",
      "method": "POST",
      "body": {
        "email_path": "./test4.eml",
        "user_accepts_danger": false
      }
    },
    "scan_upload": {
      "endpoint": "/api/v1/scan-upload",
      "method": "POST",
      "multipart": {
        "file": "<binary .eml file>",
        "user_accepts_danger": false
      }
    }
  },
