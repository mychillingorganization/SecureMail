# ============================================================
# Dockerfile.linux — Sandbox container cho scripts
# Dành cho: .js (Node) / .py / .sh / .vbs / .ps1
#
# Build:  docker build -f Dockerfile.linux -t file_agent_linux .
# ============================================================

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    nodejs \
    npm \
    tcpdump \
    strace \
    procps \
    iproute2 \
    net-tools \
    curl \
    wget \
    # PowerShell (cho .ps1)
    && apt-get install -y wget apt-transport-https software-properties-common \
    && wget -q "https://packages.microsoft.com/config/ubuntu/22.04/packages-microsoft-prod.deb" \
    && dpkg -i packages-microsoft-prod.deb 2>/dev/null || true \
    && apt-get update \
    && apt-get install -y powershell 2>/dev/null || true \
    && rm -rf /var/lib/apt/lists/* packages-microsoft-prod.deb

RUN pip3 install --break-system-packages psutil watchdog 2>/dev/null || \
    pip3 install psutil watchdog

WORKDIR /sandbox
COPY Sandbox/Monitor.py /sandbox/monitor.py
COPY Sandbox/entrypoint_linux.sh /sandbox/entrypoint_linux.sh
RUN chmod +x /sandbox/entrypoint_linux.sh

ENTRYPOINT ["/sandbox/entrypoint_linux.sh"]