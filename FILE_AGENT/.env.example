# File Agent Configuration (.env)
# Copy file này thành .env và điền API keys

# ─────────────────────────────────────────────
# Redis (Cache)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=604800  # 7 ngày

# ─────────────────────────────────────────────
# ClamAV (DISABLED by default — unreliable)
# ─────────────────────────────────────────────
# CLAMD_HOST=localhost
# CLAMD_PORT=3310
# CLAMD_ENABLED=false

# ─────────────────────────────────────────────
# PostgreSQL (IOC Database)
# ❌ Not required — using fallback in-memory store
# ─────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://fileagent:fileagent@localhost:5432/fileagent



# ─────────────────────────────────────────────
# XGBoost Classifier
# ─────────────────────────────────────────────
XGBOOST_MODEL_PATH=../dataset/model.pkl
XGBOOST_CONFIDENCE_THRESHOLD=0.70
XGBOOST_IS_PRIMARY_SCORER=true

# ─────────────────────────────────────────────
# FastAPI Runtime
# ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
LOG_LEVEL=INFO
API_SECRET_KEY=change_me_in_production

# ─────────────────────────────────────────────
# Sandbox
# ─────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=90
WINE_EXEC_TIMEOUT_SECONDS=60

# ─────────────────────────────────────────────
# YARA Rules
# ─────────────────────────────────────────────
YARA_RULES_DIR=../yara_rules
