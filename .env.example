# SecureMail environment template
# Copy this file to .env and adjust values for your environment.

# -----------------------------------------------------------------------------
# Core / Database
# -----------------------------------------------------------------------------
POSTGRES_DB=securemail
POSTGRES_USER=securemail
POSTGRES_PASSWORD=securemail
SECUREMAIL_DATABASE_URL=postgresql+asyncpg://securemail:securemail@localhost:5432/securemail

# Optional dev helper output location
SECUREMAIL_SCAN_OUTPUT_DIR=orchestra/scan_results

# Disable CLI progress bars (set to 1/true/yes)
SECUREMAIL_NO_PROGRESS=false

# -----------------------------------------------------------------------------
# Orchestrator (prefix: SECUREMAIL_)
# -----------------------------------------------------------------------------
SECUREMAIL_SERVICE_NAME=orchestrator
SECUREMAIL_EMAIL_AGENT_URL=http://localhost:8000
SECUREMAIL_FILE_AGENT_URL=http://localhost:8001
SECUREMAIL_WEB_AGENT_URL=http://localhost:8002
SECUREMAIL_AI_AGENT_URL=http://localhost:8003
SECUREMAIL_CORS_ALLOW_ORIGINS=*

SECUREMAIL_REQUEST_TIMEOUT_SECONDS=12
SECUREMAIL_AI_AGENT_TIMEOUT_SECONDS=30
SECUREMAIL_AI_AGENT_RETRY_ATTEMPTS=2
SECUREMAIL_AI_AGENT_RETRY_BACKOFF_SECONDS=1.0
SECUREMAIL_EMAIL_SUSPICIOUS_THRESHOLD=0.4
SECUREMAIL_COUNT_FILE_AGENT_UNAVAILABLE_AS_ISSUE=true

# Google AI Studio (used by orchestrator and optional AI routing)
SECUREMAIL_GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here
SECUREMAIL_GOOGLE_AI_STUDIO_MODEL=gemini-3.1-flash-lite-preview
SECUREMAIL_GOOGLE_AI_STUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Comma-separated SHA256 hashes treated as malicious by threat intel shortcut
SECUREMAIL_THREAT_INTEL_MALICIOUS_HASHES=sha256_hash_1,sha256_hash_2

# -----------------------------------------------------------------------------
# AI module (prefix: SECUREMAIL_AI_AGENT_)
# -----------------------------------------------------------------------------
SECUREMAIL_AI_AGENT_SERVICE_NAME=ai-agent
SECUREMAIL_AI_AGENT_PROVIDER=gemini
SECUREMAIL_AI_AGENT_REQUEST_TIMEOUT_SECONDS=45
SECUREMAIL_AI_AGENT_AUTONOMOUS_MAX_ATTEMPTS=3
SECUREMAIL_AI_AGENT_AUTONOMOUS_RETRY_BACKOFF_SECONDS=1.0
SECUREMAIL_AI_AGENT_AUTONOMOUS_TEMPERATURE=0.2
SECUREMAIL_AI_AGENT_AUTONOMOUS_MAX_TOOL_STEPS=8
SECUREMAIL_AI_AGENT_TRANSIENT_MAX_RETRIES=3
SECUREMAIL_AI_AGENT_TRANSIENT_RETRY_BASE_SECONDS=0.5

SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here
SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_MODEL=gemini-3.1-flash-lite-preview
SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_REVIEWER_MODEL=gemma-3-27b-it
SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SECUREMAIL_AI_AGENT_JSON_REVIEWER_ENABLED=true
SECUREMAIL_AI_AGENT_JSON_REVIEWER_ON_ERROR_ONLY=true
SECUREMAIL_AI_AGENT_JSON_REVIEWER_MAX_ATTEMPTS=1
SECUREMAIL_AI_AGENT_GEMINI_PRIMARY_RPM_LIMIT=15
SECUREMAIL_AI_AGENT_GEMMA_REVIEWER_RPM_LIMIT=30

# -----------------------------------------------------------------------------
# Email module
# -----------------------------------------------------------------------------
# Optional override for model artifact directory
EMAIL_AGENT_MODEL_DIR=/absolute/path/to/email_module/models

# -----------------------------------------------------------------------------
# File module
# -----------------------------------------------------------------------------
# pydantic settings are case-insensitive in this module.
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=604800
DATABASE_URL=postgresql+asyncpg://fileagent:fileagent@localhost:5432/fileagent

CLAMD_HOST=localhost
CLAMD_PORT=3310
CLAMD_TIMEOUT=5
CLAMD_ENABLED=false
CLAMD_RISK_WEIGHT=0.0

SANDBOX_TIMEOUT_SECONDS=90
WINE_EXEC_TIMEOUT_SECONDS=60
YARA_RULES_DIR=../yara_rules

XGBOOST_MODEL_PATH=./models/model_word.pkl
XGBOOST_CONFIDENCE_THRESHOLD=0.70
XGBOOST_IS_PRIMARY_SCORER=true

MAX_UPLOAD_SIZE_MB=50
API_SECRET_KEY=change_me_in_production
LOG_LEVEL=INFO

# Optional override for dynamic model selection path
FILE_AGENT_MODEL_DIR=/absolute/path/to/file_module/file_module/models

# -----------------------------------------------------------------------------
# Web module
# -----------------------------------------------------------------------------
MODEL_PATH=web_module/models/xgboost_phishing_model.json
MODEL_DATASET_PATH=web_module/models/fast_url_features.csv
MODEL_NOTEBOOK_PATH=web_module/models/train_model_notebook.ipynb

THREAT_LIST_REFRESH_INTERVAL=1800
WHITELIST_FILE=src/db/data/lists/whitelist.txt
BLACKLIST_FILE=src/db/data/lists/blacklist.txt
BLACKLIST_FETCH_TIMEOUT=8

WEB_AGENT_MAX_URLS_PER_REQUEST=100
WEB_AGENT_MAX_URL_LENGTH=2048

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
# SecureMail Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL database name
POSTGRES_DB=securemail

# PostgreSQL user for database access
POSTGRES_USER=securemail

# PostgreSQL password (change this in production!)
POSTGRES_PASSWORD=securemail

# Full database connection URL for the application
# Format: postgresql+asyncpg://user:password@host:port/database
SECUREMAIL_DATABASE_URL=postgresql+asyncpg://securemail:securemail@postgres:5432/securemail

# ============================================================================
# Service URLs (Microservices Communication)
# ============================================================================

# Email Agent service URL (SPF/DKIM/DMARC verification, phishing detection)
# Local: http://127.0.0.1:8000
# Docker: http://email:8000 (internal network)
SECUREMAIL_EMAIL_AGENT_URL=http://127.0.0.1:8000

# File Agent service URL (malware detection, file analysis)
# Local: http://127.0.0.1:8001
# Docker: http://file:8001 (internal network)
SECUREMAIL_FILE_AGENT_URL=http://127.0.0.1:8001

# Web Agent service URL (URL threat analysis, domain reputation)
# Local: http://127.0.0.1:8002
# Docker: http://web:8002 (internal network)
SECUREMAIL_WEB_AGENT_URL=http://127.0.0.1:8002

# AI Agent service URL (LLM reasoning, autonomous tool calling)
# Local: http://127.0.0.1:8003
# Docker: http://ai:8003 (internal network)
SECUREMAIL_AI_AGENT_URL=http://127.0.0.1:8003

# ============================================================================
# LLM Configuration (Gemini API)
# ============================================================================

# Google AI Studio API Key for Gemini LLM
# Get key from: https://ai.google.dev
SECUREMAIL_GOOGLE_AI_STUDIO_API_KEY=your_gemini_api_key_here

# Primary API key for AI Agent (can differ from above if needed)
SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_API_KEY=your_gemini_api_key_here

# Gemini model version to use for AI reasoning
# Options: gemini-3.1-flash-lite-preview, gemini-3-5-sonnet, etc.
SECUREMAIL_AI_AGENT_GOOGLE_AI_STUDIO_MODEL=gemini-3.1-flash-lite-preview

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, staging, or production
ENVIRONMENT=development

# Request timeout in seconds for inter-service calls
REQUEST_TIMEOUT_SECONDS=30

# AI Agent timeout in seconds (for LLM reasoning)
AI_AGENT_TIMEOUT_SECONDS=60

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable CORS for frontend access
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://127.0.0.1:5173"]

# ============================================================================
# Redis Configuration (Optional, for caching)
# ============================================================================

# Redis connection URL (optional, for caching and sessions)
# Format: redis://user:password@host:port/db
# REDIS_URL=redis://127.0.0.1:6379/0

# ============================================================================
# Security Settings (Production)
# ============================================================================

# Secret key for JWT tokens and session management
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# SQLAlchemy echo mode (log all SQL queries - debug only)
# Set to true in development, false in production
SQL_ECHO=false

# ============================================================================
# Pipeline Configuration
# ============================================================================

# Enable early termination in threat detection pipeline
ENABLE_EARLY_TERMINATION=true

# Risk threshold for automatic flagging (0.0 - 1.0)
RISK_THRESHOLD=0.5

# Confidence requirement for AI decisions (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.75

# ============================================================================
# Feature Flags
# ============================================================================

# Enable file sandboxing (requires Docker-in-Docker or similar)
ENABLE_FILE_SANDBOX=true

# Enable dynamic file analysis
ENABLE_DYNAMIC_ANALYSIS=true

# Enable URL reputation checks
ENABLE_URL_REPUTATION=true

# Enable email protocol verification
ENABLE_EMAIL_VERIFICATION=true

# ============================================================================
# Notes for Different Environments
# ============================================================================

# DEVELOPMENT:
#   - Use local service URLs (127.0.0.1)
#   - Set ENVIRONMENT=development
#   - Use test API keys
#   - Enable SQL_ECHO=true for debugging

# DOCKER LOCAL:
#   - Service URLs should point to container names (e.g., http://email:8000)
#   - Use docker-compose.yml or docker-compose.dev.yml
#   - Database URL should point to postgres service

# PRODUCTION:
#   - CHANGE all default passwords and API keys!
#   - Use docker-compose.prod.yml with resource limits
#   - Set ENVIRONMENT=production
#   - Use strong SECRET_KEY (generate with openssl)
#   - Enable SSL/TLS for all services
#   - Use managed database (avoid local PostgreSQL)
#   - Set appropriate RISK_THRESHOLD and CONFIDENCE_THRESHOLD
